# ===========================================
# BEGER-IT Environment Configuration
# Copy this file to .env and fill in your values
# ===========================================

# ------------------------------------------------------------------
# SITE CONFIGURATION
# ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=BEGER-IT
NEXT_PUBLIC_COMPANY_NAME="BEGER-IT Solutions"

# ------------------------------------------------------------------
# CONTACT INFORMATION
# ------------------------------------------------------------------
# Primary contact email
NEXT_PUBLIC_CONTACT_EMAIL=hello@beger-it.com
NEXT_PUBLIC_CONTACT_EMAIL_SUPPORT=support@beger-it.com

# Phone number (international format for tel: links)
NEXT_PUBLIC_CONTACT_PHONE=+494012345678
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY="+49 (0) 40 123 456 78"

# Business hours
NEXT_PUBLIC_CONTACT_HOURS="Mo-Fr 9:00 - 18:00"

# WhatsApp (use international format without + for wa.me links)
NEXT_PUBLIC_WHATSAPP_NUMBER=494012345678
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hallo! Ich interessiere mich für Ihre Dienstleistungen.

# Address
NEXT_PUBLIC_ADDRESS_STREET="Musterstraße 1"
NEXT_PUBLIC_ADDRESS_CITY="20457 Hamburg"
NEXT_PUBLIC_ADDRESS_COUNTRY="Deutschland"

# ------------------------------------------------------------------
# RESEND (Email Service for Contact Form)
# ------------------------------------------------------------------
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses for form submissions
RESEND_FROM_EMAIL=noreply@beger-it.com
RESEND_FROM_NAME="BEGER-IT Website"
RESEND_TO_EMAIL=hello@beger-it.com
RESEND_TO_NAME="BEGER-IT Team"

# Email subject templates
RESEND_SUBJECT_NEW_CONTACT="Neue Kontaktanfrage von {name}"
RESEND_SUBJECT_CONFIRMATION="Bestätigung Ihrer Anfrage - BEGER-IT"

# ------------------------------------------------------------------
# N8N (AI Chat Automation)
# ------------------------------------------------------------------
# Your n8n instance URL
NEXT_PUBLIC_N8N_URL=https://your-n8n-instance.com

# Webhook URL for chat responses (n8n workflow webhook)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat

# n8n API key (optional - for authenticated requests)
N8N_API_KEY=n8n_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat configuration
NEXT_PUBLIC_N8N_ENABLED=true
NEXT_PUBLIC_N8N_BOT_NAME="BEGER-IT Bot"
NEXT_PUBLIC_N8N_WELCOME_MESSAGE="Hallo! Ich bin der BEGER-IT KI-Assistent. Wie kann ich Ihnen bei Ihrer Digitalisierung helfen?"

# ------------------------------------------------------------------
# ANALYTICS & TRACKING (Optional)
# ------------------------------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_CHAT_WIDGET=true
NEXT_PUBLIC_ENABLE_CONTACT_FORM=true
